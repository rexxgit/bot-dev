{
    "version": 2,
    "functions": {
        "api/trigger.js": {
            "runtime": "nodejs20.x"
        }
    },
    "routes": [
        {
            "src": "/api/trigger",
            "dest": "/api/trigger"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}

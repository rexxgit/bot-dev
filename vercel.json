{
    "version": 2,
    "functions": {
        "api/query.py": {
            "runtime": "python3.10"
        }
    },
    "routes": [
        {
            "src": "/api/query",
            "dest": "/api/query"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}

{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/trigger",
            "dest": "/api/trigger"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}
